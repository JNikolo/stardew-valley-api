// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Character {
  id                  Int                 @id @default(autoincrement())
  name                String
  birthday_season     Season
  birthday_day        Int
  lives_in            String
  address             String
  can_marriage        Boolean
  clinic_visit_season Season
  clinic_visit_day    Int
  loved_gifts         String[]
  family              String[]
  relationships       Relationship[]
  schedule            CharacterSchedule[]
  character_image     String
}

model Relationship {
  id           Int       @id @default(autoincrement())
  character_id Int
  character    Character @relation(fields: [character_id], references: [id])
  description  String
}

model CharacterSchedule {
  id              Int       @id @default(autoincrement())
  character_id    Int
  character       Character @relation(fields: [character_id], references: [id])
  season          Season
  isRegular       Boolean
  time            String
  location        String
  specialOcassion String?
}

enum Season {
  Spring
  Summer
  Fall
  Winter
}
